# Runtime data directory. Keep generated files outside the repository.
SHOT_PLATFORM_HOME=./runtime

# OpenAI or OpenAI-compatible relay configuration.
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5

# Internal tool mode. Set false if you want username/password login.
AUTH_DISABLED=true

# Upload and admin defaults.
MAX_UPLOAD_MB=300
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
